<template>
    <lightning-card title="My Documents" icon-name="doctype:attachment">

        <template if:true={isLoading}>
            <lightning-spinner alternative-text="Loading files"></lightning-spinner>
        </template>

        <template if:true={files}>
            <lightning-datatable
                key-field="documentId"
                data={files}
                columns={columns}
                onrowaction={handleRowAction}
                hide-checkbox-column>
            </lightning-datatable>
        </template>

        <template if:true={noData}>
            <div class="slds-p-around_medium slds-text-align_center">
                No documents available.
            </div>
        </template>

        <template if:true={error}>
            <div class="slds-text-color_error slds-p-around_medium">
                {error}
            </div>
        </template>
 
    </lightning-card>
</template>
